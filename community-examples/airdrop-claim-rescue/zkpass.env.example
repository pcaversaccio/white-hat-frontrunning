# Standard Ethereum mainnet RPC for reads and tx construction.
READ_RPC_URL="https://ethereum-rpc.publicnode.com"

# Backward-compatible alias. If both are set, READ_RPC_URL wins.
PROVIDER_URL="https://ethereum-rpc.publicnode.com"
RELAY_URL="https://relay.flashbots.net"
VICTIM_PK="0xYOUR_COMPROMISED_WALLET_PRIVATE_KEY"
GAS_PK="0xYOUR_GAS_WALLET_PRIVATE_KEY"
FLASHBOTS_SIGNATURE_PK="0xYOUR_FLASHBOTS_SIGNER_PRIVATE_KEY"

# Optional safety check. If set, the script verifies VICTIM_PK derives to this address.
EXPECTED_VICTIM_WALLET="0xYOUR_COMPROMISED_WALLET_ADDRESS"

AIRDROP_CONTRACT="0xAIRDROP_CONTRACT_ADDRESS"
TOKEN_CONTRACT="0xTOKEN_CONTRACT_ADDRESS"
RECIPIENT_WALLET="0xYOUR_SAFE_WALLET_ADDRESS"
CLAIM_SELECTOR="0xFUNCTION_SELECTOR"
TRANSFER_TOKEN_AMOUNT="500000000000000000000"
CLAIM_PAYLOAD="0xSIGNED_CLAIM_PAYLOAD"

# Optional: set to true to send eth_callBundle before each submission.
SIMULATE_BUNDLE="false"

# Optional: comma-separated builder names for eth_sendBundle multiplexing.
# Example:
# BUNDLE_BUILDERS="builder0x69,beaverbuild.org,rsync-builder"
BUNDLE_BUILDERS=""

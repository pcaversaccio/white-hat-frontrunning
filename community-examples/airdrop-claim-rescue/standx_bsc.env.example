# Standard BNB Chain RPC for reads and tx construction.
READ_RPC_URL="https://bsc-rpc.publicnode.com"

# 48 Club private/builder RPC.
PRIVATE_RPC_URL="https://rpc.48.club"

# 48 Club Puissant bundle endpoint for bundle modes.
BUNDLE_RPC_URL="https://puissant-bsc.48.club"

# Supported modes:
#   request_withdraw_bundle
#   watch_and_rescue_bundle
MODE="request_withdraw_bundle"

VICTIM_PK="0xYOUR_COMPROMISED_WALLET_PRIVATE_KEY"
GAS_PK="0xYOUR_GAS_WALLET_PRIVATE_KEY"

# Optional safety check. If set, the script verifies VICTIM_PK derives to this address.
EXPECTED_VICTIM_WALLET="0xYOUR_COMPROMISED_WALLET_ADDRESS"

SAFE_WALLET="0xYOUR_SAFE_WALLET_ADDRESS"
STANDX_HIGHWAY="0xSTANDX_HIGHWAY_CONTRACT"
DUSD_TOKEN="0xDUSD_TOKEN_ADDRESS"
WITHDRAW_SELECTOR="0xFUNCTION_SELECTOR"
WITHDRAW_AMOUNT="1000000"
WITHDRAW_PAYLOAD="0xSIGNED_WITHDRAW_PAYLOAD"

# Poll interval for watch_and_rescue mode.
POLL_INTERVAL_SECONDS="5"

# Optional: fixed DUSD amount to transfer in watch_and_rescue_bundle mode.
# Leave empty to transfer the full detected balance.
RESCUE_TRANSFER_AMOUNT=""

# Bundle controls.
SIMULATE_BUNDLE="true"
SEND_BLOCK_COUNT="3"
MAX_BLOCK_AHEAD="100"
